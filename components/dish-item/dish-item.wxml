<view class="dish-card" bindtap="onCardTap">
  <view class="dish-img-wrap">
    <image
      wx:if="{{dish.image}}"
      class="dish-img"
      src="{{dish.image}}"
      mode="aspectFill"
      lazy-load
    />
    <text wx:else class="dish-emoji">{{dish.emoji}}</text>
  </view>
  <view class="dish-info">
    <text class="dish-name">{{dish.name}}</text>
    <text class="dish-desc">{{dish.desc}}</text>
    <view class="dish-bottom">
      <text class="dish-price">¥{{dish.price}}</text>
      <view class="dish-add-btn" catchtap="onAddTap">
        <text class="add-icon">＋</text>
      </view>
    </view>
  </view>
</view>
