.dish-card {
  display: flex;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #edf6f6;
  background: #fff;
}

.dish-img-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: #f0fafa;
}

.dish-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  display: block;
}

.dish-emoji {
  font-size: 72rpx;
}

.dish-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  margin-left: 20rpx;
  justify-content: space-between;
  overflow: hidden;
}

.dish-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-desc {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 6rpx;
}

.dish-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 10rpx;
}

.dish-price {
  font-size: 34rpx;
  font-weight: 700;
  color: #3aabaf;
}

.dish-add-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6CC6CB, #5ab5ba);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.15s;
}

.dish-add-btn:active {
  transform: scale(0.9);
}

.add-icon {
  font-size: 32rpx;
  color: #fff;
  font-weight: 700;
  line-height: 1;
}
