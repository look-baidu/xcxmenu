<!-- 遮罩层 -->
<view class="overlay {{show ? 'show' : ''}}" bindtap="onClose" catchtouchmove="preventScroll"></view>

<!-- 购物车弹窗 -->
<view class="popup {{show ? 'show' : ''}}">
  <!-- 头部 -->
  <view class="popup-header">
    <text class="popup-title">购物车</text>
    <view class="popup-clear" bindtap="onClear" wx:if="{{cart.length > 0}}">
      <text class="clear-icon">🗑️</text>
      <text class="clear-text">清空</text>
    </view>
  </view>

  <!-- 购物车列表 -->
  <scroll-view class="popup-body" scroll-y enhanced show-scrollbar="{{false}}">
    <!-- 空状态 -->
    <view class="cart-empty" wx:if="{{cart.length === 0}}">
      <text class="cart-empty-icon">🛒</text>
      <text class="cart-empty-text">购物车为空，请添加菜品</text>
    </view>

    <!-- 列表项 -->
    <view class="cart-item" wx:for="{{cart}}" wx:key="id">
      <view class="cart-item-left">
        <text class="cart-item-emoji">{{item.emoji}}</text>
        <view class="cart-item-info">
          <text class="cart-item-name">{{item.name}}</text>
          <text class="cart-item-price">¥{{item.price}}</text>
        </view>
      </view>
      <view class="cart-item-right">
        <view class="stepper">
          <view class="stepper-btn minus" bindtap="onSubtract" data-id="{{item.id}}">
            <text>－</text>
          </view>
          <text class="stepper-count">{{item.quantity}}</text>
          <view class="stepper-btn plus" bindtap="onAdd" data-id="{{item.id}}">
            <text>＋</text>
          </view>
        </view>
        <text class="cart-item-subtotal">¥{{item.price * item.quantity}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 底部汇总 -->
  <view class="popup-footer" wx:if="{{cart.length > 0}}">
    <view class="footer-total">
      <text class="footer-total-label">合计：</text>
      <text class="footer-total-price">¥{{totalPrice}}</text>
    </view>
    <view class="footer-order-btn" bindtap="onOrder">下单</view>
  </view>
</view>
