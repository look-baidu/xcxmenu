/* ========== 整体页面 ========== */
.detail-page {
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ========== 菜品头部 ========== */
.dish-header {
  background: #fff;
  margin-bottom: 16rpx;
}

.dish-cover {
  width: 100%;
  height: 420rpx;
  display: block;
}

.dish-header-info {
  padding: 28rpx 32rpx 24rpx;
}

.dish-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.dish-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.dish-tag {
  display: inline-flex;
  background: #6CC6CB;
  border-radius: 24rpx;
  padding: 4rpx 20rpx;
}

.tag-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}

/* ========== 分隔标题 ========== */
.section-divider {
  background: #fff;
  padding: 24rpx 32rpx;
  margin-bottom: 8rpx;
  border-left: 8rpx solid #6CC6CB;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

/* ========== 加载 ========== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e0e0e0;
  border-top-color: #6CC6CB;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* ========== 错误 ========== */
.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 28rpx;
  color: #999;
  text-align: center;
}

/* ========== Markdown 内容 ========== */
.md-content {
  background: #fff;
  padding: 24rpx 32rpx;
  margin: 0 0 16rpx;
}

.md-h1 {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin: 32rpx 0 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #e0e0e0;
}

.md-h2 {
  font-size: 34rpx;
  font-weight: 700;
  color: #2c2c2c;
  margin: 28rpx 0 14rpx;
  padding-left: 12rpx;
  border-left: 6rpx solid #6CC6CB;
}

.md-h3 {
  font-size: 30rpx;
  font-weight: 600;
  color: #444;
  margin: 20rpx 0 10rpx;
}

.md-p {
  font-size: 28rpx;
  color: #444;
  line-height: 1.8;
  margin: 8rpx 0;
}

.md-li {
  display: flex;
  align-items: flex-start;
  margin: 8rpx 0;
  padding-left: 8rpx;
}

.li-dot {
  font-size: 28rpx;
  color: #6CC6CB;
  margin-right: 12rpx;
  flex-shrink: 0;
  line-height: 1.8;
}

.li-text {
  font-size: 28rpx;
  color: #444;
  line-height: 1.8;
  flex: 1;
}

.md-img {
  width: 100%;
  border-radius: 12rpx;
  margin: 16rpx 0;
  display: block;
}

.md-hr {
  height: 2rpx;
  background: #e8e8e8;
  margin: 24rpx 0;
}

.md-blank {
  height: 12rpx;
}

/* ========== 底部留白 ========== */
.footer-pad {
  height: 60rpx;
}
