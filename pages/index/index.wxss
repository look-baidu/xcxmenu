page {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: #f0f4f4;
  overflow: hidden;
}

/* ========== 搜索栏 ========== */
.search-bar {
  flex-shrink: 0;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #6CC6CB 0%, #5ab5ba 100%);
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 36rpx;
  padding: 0 24rpx;
  height: 68rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 68rpx;
  line-height: 68rpx;
}

.search-clear {
  font-size: 28rpx;
  color: #999;
  padding: 8rpx;
  flex-shrink: 0;
}

/* ========== 主体区域 ========== */
.main-content {
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* ========== 左侧分类栏 ========== */
.sidebar {
  width: 180rpx;
  flex-shrink: 0;
  background: linear-gradient(180deg, #edf6f6 0%, #EAE5C9 100%);
  height: 100%;
}

.category-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  font-size: 26rpx;
  color: #666;
  position: relative;
  transition: all 0.2s;
}

.category-item.active {
  background: #fff;
  color: #3aabaf;
  font-weight: 600;
}

.category-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 40rpx;
  background: linear-gradient(180deg, #6CC6CB, #a8d8a8);
  border-radius: 0 3rpx 3rpx 0;
}

/* ========== 右侧菜品区 ========== */
.dish-area {
  flex: 1;
  min-width: 0;
  height: 100%;
  background: #fff;
  box-sizing: border-box;
  width: 0;
}

.section-header {
  padding: 20rpx 24rpx 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #3aabaf;
  background: linear-gradient(90deg, #f5fbfb 0%, #fdfcf7 100%);
  position: sticky;
  top: 0;
  z-index: 5;
  border-bottom: 1rpx solid #e8f4f4;
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

/* ========== 底部购物车栏 ========== */
.cart-bar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  height: 100rpx;
  background: linear-gradient(135deg, #4db8bd 0%, #3aabaf 100%);
  padding-left: 24rpx;
  position: relative;
  z-index: 100;
}

.cart-bar-left {
  flex: 1;
  display: flex;
  align-items: center;
  height: 100%;
}

.cart-icon-wrap {
  position: relative;
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #6CC6CB, #5ab5ba);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: -30rpx;
  border: 4rpx solid #3aabaf;
}

.cart-icon-text {
  font-size: 44rpx;
}

.cart-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  background: #ff4444;
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 18rpx;
  padding: 0 8rpx;
}

.cart-info {
  margin-left: 20rpx;
}

.cart-total-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.cart-empty-text {
  font-size: 26rpx;
  color: white;
}

.cart-checkout-btn {
  width: 220rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #EAE5C9, #d4ceaa);
  color: #3aabaf;
  font-size: 30rpx;
  font-weight: 600;
}

.cart-checkout-btn.disabled {
  background: rgba(255,255,255,0.2);
  color: rgba(255,255,255,0.5);
}
