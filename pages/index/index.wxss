.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
  overflow: hidden;
}

/* ========== 搜索栏 ========== */
.search-bar {
  flex-shrink: 0;
  padding: 16rpx 24rpx;
  background: #ff6b35;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 36rpx;
  padding: 0 24rpx;
  height: 68rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 68rpx;
  line-height: 68rpx;
}

.search-clear {
  font-size: 28rpx;
  color: #999;
  padding: 8rpx;
  flex-shrink: 0;
}

/* ========== 主体区域 ========== */
.main-content {
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* ========== 左侧分类栏 ========== */
.sidebar {
  width: 180rpx;
  flex-shrink: 0;
  background: #fafafa;
  height: 100%;
}

.category-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  font-size: 26rpx;
  color: #666;
  position: relative;
  transition: all 0.2s;
}

.category-item.active {
  background: #fff;
  color: #ff6b35;
  font-weight: 600;
}

.category-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 40rpx;
  background: #ff6b35;
  border-radius: 0 3rpx 3rpx 0;
}

/* ========== 右侧菜品区 ========== */
.dish-area {
  flex: 1;
  height: 100%;
  background: #fff;
}

.section-header {
  padding: 20rpx 24rpx 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 5;
  border-bottom: 1rpx solid #f0f0f0;
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

/* ========== 底部购物车栏 ========== */
.cart-bar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  height: 100rpx;
  background: #2d2d2d;
  padding-left: 24rpx;
  position: relative;
  z-index: 100;
}

.cart-bar-left {
  flex: 1;
  display: flex;
  align-items: center;
  height: 100%;
}

.cart-icon-wrap {
  position: relative;
  width: 88rpx;
  height: 88rpx;
  background: #3d3d3d;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: -30rpx;
  border: 4rpx solid #2d2d2d;
}

.cart-icon-text {
  font-size: 44rpx;
}

.cart-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  background: #ff4444;
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 18rpx;
  padding: 0 8rpx;
}

.cart-info {
  margin-left: 20rpx;
}

.cart-total-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.cart-empty-text {
  font-size: 26rpx;
  color: #999;
}

.cart-checkout-btn {
  width: 220rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ff6b35;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

.cart-checkout-btn.disabled {
  background: #535353;
  color: #888;
}
